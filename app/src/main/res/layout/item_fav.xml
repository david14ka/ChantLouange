<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="13dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Number pill / badge -->
    <TextView
        android:id="@+id/txt_number"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/ed_accent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/fav_number_pill"
        android:fontFamily="sans-serif-medium" />

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/txt_tittle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quel est cet homme de Jesus"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:lines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/txt_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Collection des Cantiques"
            android:textColor="@color/ed_text_secondary"
            android:textSize="12sp"
            android:lines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Star / fav indicator (hidden by default, kept for compat) -->
    <ImageView
        android:id="@+id/fav"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/star0"
        android:visibility="gone" />

    <!-- Three-dot context menu -->
    <ImageView
        android:id="@+id/item_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/ic_more_vert_black_24dp"
        android:tint="@color/ed_text_secondary"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="More options" />

</LinearLayout>
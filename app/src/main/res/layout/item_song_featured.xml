<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingVertical="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#2D1B1B"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/lbl_archive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARCHIVE VEDETTE"
                android:textColor="@color/home_cat_text"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/txt_archive_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/lbl_archive"
                android:layout_marginTop="8dp"
                android:text="Les Hymnes de la Réforme"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/txt_archive_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/txt_archive_title"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="80dp"
                android:text="Découvrez la collection complète des chants classiques du XVIe siècle restaurés numériquement."
                android:textColor="@color/home_text_body"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.2" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

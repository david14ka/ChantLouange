<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/item_song_border"
    android:paddingVertical="12dp"
    android:paddingHorizontal="16dp">

        <!-- Hymn Number -->
        <TextView
            android:id="@+id/txt_number"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            tools:text="344B"
            android:textColor="@color/on_primary_container"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/txt_tittle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/txt_number"
            app:layout_constraintEnd_toStartOf="@+id/fav" />

        <!-- Secondary elements (Notes / Favorites) pinned to top right -->
        <ImageView
            android:id="@+id/fav"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/star0"
            app:tint="@color/tertiary_fixed"
            android:visibility="gone"
            android:contentDescription="@string/fav_preferences"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Kept for backward compatibility with ListFragment -->
        <ImageView
            android:id="@+id/note"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/note"
            app:tint="@color/tertiary_fixed"
            android:visibility="gone"
            android:contentDescription="@string/note"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
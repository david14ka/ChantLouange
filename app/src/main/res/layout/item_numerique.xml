<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/song_item_bg_glass">

        <!-- Accent gauche (Indicateur rouge pour audio/sélection) -->
        <View
            android:id="@+id/accent_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_left_accent"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Numéro box - Premium Rounded Square -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/pill_active_bg">

            <TextView
                android:id="@+id/txt_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:textStyle="italic|bold"
                tools:text="05" />
        </FrameLayout>

        <!-- Titre + sous-titre -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/txt_tittle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Grâce infinie" />

            <TextView
                android:id="@+id/txt_original_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#BDBDBD"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.04"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="AMAZING GRACE" />
        </LinearLayout>

        <!-- Icônes droites -->
        <!-- Play Icon (Red circular style as in image) -->
        <ImageView
            android:id="@+id/note"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_play_red"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Bookmark/Fav -->
        <ImageView
            android:id="@+id/fav"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_bookmark"
            app:tint="#E53935"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/chevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/forward_24px"
            app:tint="#66FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/txt_letter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</androidx.cardview.widget.CardView>
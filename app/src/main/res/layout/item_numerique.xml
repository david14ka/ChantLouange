<?xml version="1.0" encoding="utf-8"?>
<!--
    Item allégé : LinearLayout simple au lieu de CardView+ConstraintLayout.
    L'inflation est ~3x plus rapide. Séparateur via un View fin en bas.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="13dp"
    android:background="?android:attr/selectableItemBackground"
    android:minHeight="56dp">

    <!-- Accent gauche favori -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="3dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_left_accent"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Numéro -->
    <TextView
        android:id="@+id/txt_number"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:gravity="center"
        android:textColor="#F5E0B7"
        android:textSize="18sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        tools:text="01" />

    <!-- Titre + sous-titre -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/txt_tittle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EEEEEE"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Gloire à Dieu dans les cieux" />

        <TextView
            android:id="@+id/txt_original_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.04"
            android:visibility="gone"
            tools:text="GLORIA IN EXCELSIS" />
    </LinearLayout>

    <!-- Icônes droites -->
    <ImageView
        android:id="@+id/fav"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_bookmark"
        app:tint="@color/red"
        android:visibility="gone"
        tools:visibility="visible"
        android:contentDescription="@string/fav_preferences" />

    <ImageView
        android:id="@+id/chevron"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/forward_24px"
        app:tint="#444444" />

    <!-- Stubs pour la compat adapter (ButterKnife @BindView) -->
    <ImageView
        android:id="@+id/note"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/note"
        android:visibility="gone" />

    <!-- Stub pour txt_letter qui était utilisé pour le mode alphabétique -->
    <TextView
        android:id="@+id/txt_letter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Séparateur -->
</LinearLayout>

<!-- Séparateur fin entre les items -->
<!--
NOTE: Le séparateur est mieux géré via ItemDecoration dans Java
(DividerItemDecoration), mais pour un résultat clé-en-main sans
toucher au Java, un ItemDecoration suffit dans ListFragment.
-->
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/txt_number"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textColor="#A0332D"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:gravity="start|center_vertical"
        android:letterSpacing="-0.02"
        android:includeFontPadding="false"
        tools:text="042" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/home_cat_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:includeFontPadding="false"
            tools:text="Grand Dieu, nous te bénissons" />

        <TextView
            android:id="@+id/txt_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/home_text_body"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            tools:text="Adoration &amp; Louange" />

    </LinearLayout>

    <ImageView
        android:id="@+id/img_fav"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/star_filed"
        app:tint="@color/home_cat_text"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_marginStart="16dp"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>

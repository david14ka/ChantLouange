<?xml version="1.0" encoding="utf-8"?>
<!--
    Fragment allégé.
    IMPORTANT : RecyclerView DIRECT, pas de NestedScrollView.
    Le vrai recyclage de vues fonctionne → seules ~20 lignes visibles
    sont en mémoire, même pour un livre de 650 cantiques.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Liste principale -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_song"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@null"
        android:paddingTop="4dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_numerique" />

    <!-- Résultats livres croisés — vue séparée, glisse après la liste principale -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_other_books"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:listitem="@layout/item_search_result" />

    <!-- Vue vide (aucun résultat) -->
    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="center"
            android:text="@string/no_results" />

        <Button
            android:id="@+id/btn_search_other_books"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/search_in_other_books"
            android:textColor="#E53935"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Vues de compatibilité cachées (utilisées par le fragment Java) -->
    <TextView
        android:id="@+id/result_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="4dp"
        android:layout_marginStart="20dp"
        android:paddingVertical="4dp"
        android:textSize="12sp"
        android:textColor="#E53935"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="5 résultats" />

    <TextView
        android:id="@+id/txt_other_books_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp"
        android:text="@string/found_in_other_books"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="#E53935"
        android:visibility="gone" />

    <CheckBox
        android:id="@+id/check_search_lyrics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:text="@string/search_in_lyrics"
        android:textColor="#888888"
        android:buttonTint="#E53935"
        android:textSize="13sp"
        android:visibility="gone" />

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@null">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- Result count bar — shown only during an active search -->
        <TextView
            android:id="@+id/result_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:textSize="12sp"
            android:textColor="#E53935"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="5 songs found"
            tools:visibility="visible"/>

        <!-- Search in lyrics option -->
        <CheckBox
            android:id="@+id/check_search_lyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:text="@string/search_in_lyrics"
            android:textColor="#888888"
            android:buttonTint="#E53935"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_song"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingTop="8dp"
            android:visibility="visible"
            tools:listitem="@layout/item_numerique" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="48sp"/>

            <TextView
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="16sp"
                android:textColor="#888888"
                android:gravity="center"
                android:text="@string/no_results"/>

            <Button
                android:id="@+id/btn_search_other_books"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/search_in_other_books"
                android:textColor="#E53935"
                android:textAllCaps="false"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Cross-book results section -->
        <TextView
            android:id="@+id/txt_other_books_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="@string/found_in_other_books"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textColor="#E53935"
            android:visibility="gone"
            tools:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_other_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            tools:visibility="visible"
            tools:listitem="@layout/item_search_result"/>

        <!-- ── Scripture quote card (Editorial Design) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0F0F0F">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Decorative icon background -->
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="end|bottom"
                    android:src="@drawable/literature_96px"
                    android:alpha="0.05"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="-20dp"
                    android:layout_marginBottom="-20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:textStyle="italic"
                        android:textColor="#EEEEEE"
                        android:textSize="18sp"
                        android:lineSpacingMultiplier="1.3"
                        android:text="&quot;Chantez à l&apos;Éternel un cantique nouveau ! Chantez à l&apos;Éternel, vous tous, habitants de la terre !&quot;" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="PSAUME 96:1"
                        android:textColor="#E53935"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
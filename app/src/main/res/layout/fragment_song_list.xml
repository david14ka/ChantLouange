<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/layout"
    android:orientation="vertical"
    android:background="@null">

    <!-- Result count bar — shown only during an active search -->
    <TextView
        android:id="@+id/result_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:textSize="12sp"
        android:textColor="#E53935"
        android:visibility="gone"
        tools:text="5 songs found"
        tools:visibility="visible"/>

    <!-- Search in lyrics option -->
    <CheckBox
        android:id="@+id/check_search_lyrics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:text="@string/search_in_lyrics"
        android:textColor="#CCCCCC"
        android:buttonTint="#E53935"
        android:visibility="gone"
        tools:visibility="visible" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_song"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="160dp"
            android:clipToPadding="false"
            android:visibility="visible"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128269;"
                android:textSize="48sp"/>

            <TextView
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="16sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:text="@string/no_results"/>

            <Button
                android:id="@+id/btn_search_other_books"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/search_in_other_books"
                android:textColor="#E53935"
                android:textAllCaps="false"
                android:visibility="gone"/>
        </LinearLayout>

    </FrameLayout>

    <!-- Cross-book results section -->
    <TextView
        android:id="@+id/txt_other_books_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:text="@string/found_in_other_books"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="#E53935"
        android:visibility="gone"
        tools:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_other_books"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:visibility="gone"
        tools:visibility="visible"
        tools:listitem="@layout/item_search_result"/>

    <!-- ── Scripture quote footer ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textColor="#DDDDDD"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:text="&quot;Chantez à l&apos;Éternel un chant nouveau\u202F! Chantez à l&apos;Éternel, vous tous, habitants de la terre\u202F!&quot;" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="PSAUME 96:1"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

</LinearLayout>
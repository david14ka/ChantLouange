<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <!-- Image de fond (Piano) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/piano"
        android:scaleType="centerCrop"
        android:alpha="0.25" />

    <!-- Contenu principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/txt_nos_chants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_nos_chants"
                android:textColor="@color/home_cat_text"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/txt_song_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBaseline="@+id/txt_nos_chants"
                android:layout_alignParentEnd="true"
                android:text="1,240 HYMNES"
                android:textColor="@color/home_text_body"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </RelativeLayout>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/search_pill_bg"
            android:backgroundTint="#1A1A1A"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:elevation="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search_black_24dp"
                app:tint="@color/home_text_body" />

            <EditText
                android:id="@+id/edt_search_songs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="@string/search_hint"
                android:textColorHint="@color/home_text_body"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="textNoSuggestions" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/check_search_lyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_lyrics_label"
            android:textColor="@color/home_text_body"
            android:textSize="12sp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            app:buttonTint="@color/primary_container" />

        <!-- Filter Pills -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_filter_az"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-Z"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/pill_active_bg" />

                <TextView
                    android:id="@+id/btn_filter_numero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/filter_number"
                    android:textColor="@color/ed_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/pill_inactive_bg" />

                <TextView
                    android:id="@+id/btn_filter_recueil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/filter_book"
                    android:textColor="@color/ed_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/pill_inactive_bg" />

                <TextView
                    android:id="@+id/btn_filter_favoris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/filter_fav"
                    android:textColor="@color/ed_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/pill_inactive_bg" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_all_songs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />

    </LinearLayout>

</FrameLayout>

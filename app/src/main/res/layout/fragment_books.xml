<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero Header ──────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Background Image with Transparency -->
            <!-- Transparence ajustable ici, 0.2 = 20% -->

            <ImageView
                android:layout_width="421dp"
                android:layout_height="257dp"
                android:alpha="0.2"
                android:scaleType="centerCrop"
                android:src="@drawable/audience2_868074_640" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_title"
                    android:textColor="@color/home_cat_text"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:fontFamily="serif" />

                <!-- Séparateur décoratif -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/bg_day"
                    android:alpha="0.5" />

                <!-- Verset biblique dynamique -->
                <TextView
                    android:id="@+id/tv_verse_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bg_day"
                    android:textSize="17sp"
                    android:lineSpacingMultiplier="1.5"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    tools:text="Je lève les yeux vers les montagnes..." />

                <!-- Référence du verset -->
                <TextView
                    android:id="@+id/tv_verse_reference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/home_cat_text"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.75"
                    tools:text="— Psaume 121:1-2" />

            </LinearLayout>
        </FrameLayout>

        <!-- ── 2-Column Book Grid (RecyclerView for performance) ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="4dp"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
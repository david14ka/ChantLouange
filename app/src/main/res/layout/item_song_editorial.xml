<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="@drawable/song_item_bg_glass"
        android:clickable="true"
        android:gravity="center_vertical"
        android:focusable="true">

        <TextView
            android:id="@+id/txt_song_num"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="01"
            android:textColor="@color/primary_container"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/txt_song_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Grand Dieu, nous te bénissons"
            android:textColor="?attr/textColor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2" />

        <ImageView
            android:id="@+id/img_audio_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_headset_black_24dp"
            android:tint="@color/primary_container"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txt_song_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:maxWidth="100dp"
            android:gravity="end"
            android:text="VICTOIRE"
            android:textColor="@color/ed_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:textAllCaps="true" />

    </LinearLayout>
</androidx.cardview.widget.CardView>


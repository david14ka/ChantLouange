<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/book_height"
    android:padding="5dp"
    android:layout_margin="10dp"
android:layout_gravity="center"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/layout_book"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardElevation="3dp"
        app:cardCornerRadius="5dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/book_item_bg"
            >

            <ImageView
                android:id="@+id/book_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/title_book_detail"
                android:src="@drawable/book_bb"
                android:scaleType="centerCrop"
                />
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/item_music"
                android:src="@drawable/item_book_gradient"/>
            <TextView
                android:textColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:lines="2"
                android:background="@drawable/book_item_bg"
                android:padding="5dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="bottom"
                />

            <TextView
                android:id="@+id/book_name"
                android:textColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/collection_de_cantiques"
                android:gravity="center"
                android:lines="2"
                android:padding="5dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="bottom"/>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>